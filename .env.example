NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whareception?schema=public

# Redis (live conversation state + future job queues)
REDIS_URL=redis://localhost:6379

# Conversation state TTL in seconds (how long an in-progress conversation
# stays "active" in Redis between customer messages). Default: 24h.
CONVERSATION_STATE_TTL=86400

# WhatsApp (Meta Cloud API) — only required once real integration is enabled.
WHATSAPP_VERIFY_TOKEN=local_verify_token
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Outbound WhatsApp provider: "mock" logs sends, "meta" calls the Cloud API.
WHATSAPP_PROVIDER=mock

# LLM provider: "openai" or "mock".
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Minimum confidence (0-1) required to act on an AI intent classification.
# Below this, the conversation is routed to a human handoff.
LLM_MIN_CONFIDENCE=0.6
