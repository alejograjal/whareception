NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whareception?schema=public

# Redis (live conversation state + future job queues)
REDIS_URL=redis://localhost:6379

# Conversation state TTL in seconds (how long an in-progress conversation
# stays "active" in Redis between customer messages). Default: 24h.
CONVERSATION_STATE_TTL=86400

# WhatsApp (Meta Cloud API) — only required once real integration is enabled.
WHATSAPP_VERIFY_TOKEN=local_verify_token
# Shared access token (Model A): one System User token sends for every tenant
# number under your WABA. Required when WHATSAPP_PROVIDER=meta.
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
# Optional global fallback sender. In multi-tenant (Model A) each tenant sends
# from its own whatsappPhoneNumberId, so this is only used if a tenant has none.
WHATSAPP_PHONE_NUMBER_ID=
# App Secret (Meta App > Settings > Basic). Used to verify webhook signatures.
# Leave empty in local dev to skip signature verification for simulated calls.
WHATSAPP_APP_SECRET=

# Outbound WhatsApp provider: "mock" logs sends, "meta" calls the Cloud API.
WHATSAPP_PROVIDER=mock

# Shared secret protecting /admin/* endpoints (send as x-admin-token header).
# Leave empty to disable admin endpoints.
ADMIN_TOKEN=

# LLM provider: "openai" or "mock".
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Minimum confidence (0-1) required to act on an AI intent classification.
# Below this, the conversation is routed to a human handoff.
LLM_MIN_CONFIDENCE=0.6
